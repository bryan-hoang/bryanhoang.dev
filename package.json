{
	"name": "bryanhoang.dev",
	"type": "module",
	"scripts": {
		"astro": "astro",
		"build": "astro build",
		"check": "pnpm dlx @astrojs/check",
		"dev": "astro dev",
		"prepare": "husky",
		"preview": "astro preview"
	},
	"dependencies": {
		"astro": "6.1.6"
	},
	"devDependencies": {
		"@astrojs/ts-plugin": "1.10.7",
		"husky": "9.1.7",
		"vite-plus": "latest"
	},
	"engines": {
		"node": "24.x"
	},
	"packageManager": "pnpm@11.0.5",
	"pnpm": {
		"packageExtensions": {
			"@voidzero-dev/vite-plus-core": {
				"peerDependencies": {
					"vite-plus": "*"
				}
			}
		},
		"overrides": {
			"vite": "npm:@voidzero-dev/vite-plus-core@latest"
		},
		"onlyBuiltDependencies": [
			"esbuild",
			"sharp"
		]
	}
}
